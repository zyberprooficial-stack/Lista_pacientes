# Configuración del Sistema de Consulta de Pacientes
# Copiar este archivo a .env y ajustar los valores

# URL de conexión a PostgreSQL
# Formato: postgres://usuario:contraseña@host:puerto/nombre_db?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pacientes_db?sslmode=disable

# Puerto del servidor HTTP
PORT=8080

# Configuración del Connection Pool
MAX_DB_CONNECTIONS=20
MAX_IDLE_CONNECTIONS=5

# Rate Limiting (requests por minuto por IP)
RATE_LIMIT_PER_MINUTE=100

# Google Maps API Key para autocompletado de ubicaciones
# Obtener en: https://console.cloud.google.com/apis/credentials
# Habilitar: Places API (New) y Maps JavaScript API
GOOGLE_MAPS_API_KEY=TU_API_KEY_AQUI
